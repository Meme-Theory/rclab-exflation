    {
      "id": "eq_5216",
      "raw": "pi^o(b)(v) = J pi(b*) J^{-1}(v)",
      "type": "comment",
      "context": "The opposite algebra action is:",
      "session": "",
      "source_file": "tier0-computation\\phase25_omap_check.py",
      "line": 104,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5217",
      "raw": "# Since J^{-1} = J (because J^2 = +I):",
      "type": "comment",
      "context": "The opposite algebra action is: pi^o(b)(v) = J pi(b*) J^{-1}(v)",
      "session": "",
      "source_file": "tier0-computation\\phase25_omap_check.py",
      "line": 105,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5218",
      "raw": "pi^o(b)(v) = J( pi(b*) ( J(v) ) )",
      "type": "comment",
      "context": "Since J^{-1} = J (because J^2 = +I):",
      "session": "",
      "source_file": "tier0-computation\\phase25_omap_check.py",
      "line": 107,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5219",
      "raw": "= J( pi(b*) ( Xi @ conj(v) ) )",
      "type": "comment",
      "context": "Since J^{-1} = J (because J^2 = +I): pi^o(b)(v) = J( pi(b*) ( J(v) ) )",
      "session": "",
      "source_file": "tier0-computation\\phase25_omap_check.py",
      "line": 108,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5220",
      "raw": "= Xi @ conj( pi(b*) @ Xi @ conj(v) )",
      "type": "comment",
      "context": "pi^o(b)(v) = J( pi(b*) ( J(v) ) ) = J( pi(b*) ( Xi @ conj(v) ) )",
      "session": "",
      "source_file": "tier0-computation\\phase25_omap_check.py",
