    {
      "id": "eq_11715",
      "raw": "In each sector (p,q), the Dirac operator D_{(p,q)} acts on V_{(p,q)} x S (dim = dim(p,q) * 16).",
      "type": "code",
      "context": "The Dirac operator acts on L^2(SU(3), S) = bigoplus_{(p,q)} V_{(p,q)} x V_{(p,q)}^* x S.",
      "session": "",
      "source_file": "tier0-computation\\tier1_spectral_action.py",
      "line": 97,
