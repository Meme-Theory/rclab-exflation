  "equations": [
    {
      "id": "eq_5724",
      "raw": "Peak in C(tau) at fixed beta = lambda-point analog (second-order phase transition).",
      "type": "code",
      "context": "dS/dtau = rate of spectral complexification. Maximum identifies MEPP selected state.",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 12,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5725",
      "raw": "Compute spectral partition function Z = Sum mult_n * exp(-beta * lambda_n^2).",
      "type": "code",
      "context": "def compute_partition_function(eigenvalues, multiplicities, beta): \"\"\"",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 39,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5726",
      "raw": "lam4 = eigenvalues ** 4",
      "type": "code",
      "context": "\"\"\" lam2 = eigenvalues ** 2",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 65,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5727",
      "raw": "boltz = multiplicities * np.exp(-beta * lam2)",
      "type": "code",
      "context": "Boltzmann weights",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 68,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5728",
      "raw": "Z = np.sum(boltz)",
      "type": "code",
      "context": "Boltzmann weights boltz = multiplicities * np.exp(-beta * lam2)",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 69,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5729",
      "raw": "p = boltz / Z",
      "type": "code",
      "context": "Probabilities",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 75,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5730",
      "raw": "mask = p > 1e-300",
      "type": "code",
      "context": "Shannon entropy: S = -Sum p_n log(p_n) Avoid log(0) by filtering",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 79,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5731",
      "raw": "S = -np.sum(p[mask] * np.log(p[mask]))",
      "type": "code",
      "context": "Avoid log(0) by filtering mask = p > 1e-300",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 80,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5732",
      "raw": "lam2_mean = np.sum(p * lam2)",
      "type": "code",
      "context": "Expectation values",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
      "line": 83,
