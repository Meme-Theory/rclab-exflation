      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5733",
      "raw": "lam4_mean = np.sum(p * lam4)",
      "type": "code",
      "context": "Expectation values lam2_mean = np.sum(p * lam2)",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_entropy_capacity.py",
