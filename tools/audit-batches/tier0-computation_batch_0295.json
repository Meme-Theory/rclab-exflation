      "severity": ""
    },
    {
      "id": "eq_11896",
      "raw": "K(t) = a_0 * t^{-3/2} + a_2 * t^{-1/2} + ...",
      "type": "code",
      "context": "The Seeley-DeWitt expansion for S^3 (dim=3) is:",
      "session": "",
      "source_file": "tier0-computation\\tier1_spectral_action.py",
