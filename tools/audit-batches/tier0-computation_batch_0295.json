    },
    {
      "id": "eq_11895",
      "raw": "K(t) = sum_{k=0}^inf (k+1)(k+2) * 2 * exp(-t * ((k+3/2)/r)^2)",
      "type": "code",
      "context": "The heat kernel is:",
      "session": "",
      "source_file": "tier0-computation\\tier1_spectral_action.py",
