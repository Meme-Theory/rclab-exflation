    },
    {
      "id": "eq_2416",
      "raw": "formed from the real structure J = Xi o conj and the Dirac operator D(s).",
      "type": "code",
      "context": "Compute sgn(Pf(M(s))) where M(s) = Xi * D(s) is the antisymmetric matrix",
      "session": "",
      "source_file": "tier0-computation\\d2_pfaffian_computation.py",
