      "severity": ""
    },
    {
      "id": "eq_2417",
      "raw": "ANTISYMMETRY OF M = Xi * D",
      "type": "code",
      "context": "3. D(s) is anti-Hermitian: D^dag = -D, so eigenvalues are purely imaginary.",
      "session": "",
      "source_file": "tier0-computation\\d2_pfaffian_computation.py",
      "line": 15,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_2418",
      "raw": "M^T = (Xi*D)^T = D^T * Xi = -conj(D) * Xi = -(Xi * D) = -M",
      "type": "code",
      "context": "ANTISYMMETRY OF M = Xi * D ===========================",
      "session": "",
      "source_file": "tier0-computation\\d2_pfaffian_computation.py",
      "line": 17,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_2419",
      "raw": "(using D^T = -conj(D) and Xi*conj(D) = D*Xi from J-compatibility)",
      "type": "code",
      "context": "=========================== M^T = (Xi*D)^T = D^T * Xi = -conj(D) * Xi = -(Xi * D) = -M",
      "session": "",
      "source_file": "tier0-computation\\d2_pfaffian_computation.py",
      "line": 18,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_2420",
      "raw": "Pf(M) changes sign iff det(D) = 0 iff D has a zero eigenvalue.",
      "type": "code",
      "context": "Pf(M)^2 = det(M) = det(Xi) * det(D). det(Xi) is constant (s-independent).",
      "session": "",
      "source_file": "tier0-computation\\d2_pfaffian_computation.py",
      "line": 24,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
