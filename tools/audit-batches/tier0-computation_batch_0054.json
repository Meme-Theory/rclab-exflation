    {
      "id": "eq_3022",
      "raw": "q in H iff q = alpha*I + beta_1*i*sigma_1 + beta_2*i*sigma_2 + beta_3*i*sigma_3",
      "type": "comment",
      "context": "Where q = (q_11, q_12; q_21, q_22) is a quaternion matrix:",
      "session": "",
      "source_file": "tier0-computation\\debug_jcompat7.py",
      "line": 212,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3023",
      "raw": "This means q = (alpha + i*beta_3, beta_2 + i*beta_1;",
      "type": "comment",
      "context": "Where q = (q_11, q_12; q_21, q_22) is a quaternion matrix: q in H iff q = alpha*I + beta_1*i*sigma_1 + beta_2*i*sigma_2 + beta_3*i*sigma_3",
