      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3866",
      "raw": "Ric_endo = np.zeros((dim_sym0, dim_sym0), dtype=np.float64)",
      "type": "code",
      "context": "Let's compute both terms: dim_sym0 = basis.shape[0]",
