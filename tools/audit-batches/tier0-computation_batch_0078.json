      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3862",
      "raw": "R_endo = -2.0 * np.einsum('Iab,acbd,Jcd->IJ', basis, R_abcd, basis)",
      "type": "code",
      "context": "Verified by direct loop: R_endo[0,0] = -2 * sum_{a,b,c,d} basis[0,a,b]*R[a,c,b,d]*basis[0,c,d] = -0.1667 (non-zero, as expected).",
