      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3867",
      "raw": "Ric_E = np.einsum('ac,Jcb->Jab', Ric, basis)        # (35,8,8): Ric @ E^J",
      "type": "code",
      "context": "Precompute Ric @ basis[J] and basis[I] @ Ric for all I, J",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 236,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3868",
