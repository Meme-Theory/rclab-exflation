      "type": "code",
      "context": "Precompute Ric @ basis[J] and basis[I] @ Ric for all I, J Ric_E = np.einsum('ac,Jcb->Jab', Ric, basis)        (35,8,8): Ric @ E^J",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 237,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3869",
      "raw": "term1 = np.einsum('Iab,Jba->IJ', basis, Ric_E)",
      "type": "code",
      "context": "= einsum('Iab,Jba->IJ', basis, Ric_E) + einsum('Iab,Jba->IJ', E_Ric, basis) Note: Tr(A @ B) = sum_{a,b} A_{ab} B_{ba} = einsum('ab,ba->', A, B)",
