      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3864",
      "raw": "Ric_endo[I,J] = sum_{a,b,c} E^I_{ab} * (Ric_{ac} E^J_{cb} + Ric_{bc} E^J_{ac})",
      "type": "code",
      "context": "Matrix element:",
