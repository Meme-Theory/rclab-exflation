      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3857",
      "raw": "[R_endo]_{IJ} = Tr(E^{(I)} . R . E^{(J)})",
      "type": "code",
      "context": "In ON frame: h^{cd} = h_{cd} (index raising is trivial). Acting on basis element E^{(J)}:",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 161,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3858",
      "raw": "R_endo[I,J] = sum_{a,b,c,d} E^{I}_{ab} * (-2 R[a,c,b,d]) * E^{J}_{cd}",
      "type": "code",
      "context": "Matrix element:",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 171,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3859",
      "raw": "R_abcd[a,b,c,d] = R_{abcd}",
      "type": "code",
      "context": "Convention from r20a_riemann_tensor.py:",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 174,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3860",
      "raw": "So R_{acbd} = R_abcd[a,c,b,d].",
      "type": "code",
      "context": "Convention from r20a_riemann_tensor.py: R_abcd[a,b,c,d] = R_{abcd}",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 175,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3861",
      "raw": "n = basis.shape[1]          # 8",
      "type": "code",
      "context": "\"\"\" dim_sym0 = basis.shape[0]  35",
