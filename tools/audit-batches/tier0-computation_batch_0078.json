      "severity": ""
    },
    {
      "id": "eq_3852",
      "raw": "basis = np.zeros((dim_sym0, n, n), dtype=np.float64)",
      "type": "code",
      "context": "\"\"\" dim_sym0 = n * (n + 1) // 2 - 1  = 35 for n=8",
