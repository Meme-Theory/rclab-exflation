      "severity": ""
    },
    {
      "id": "eq_3853",
      "raw": "E = np.zeros((n, n), dtype=np.float64)",
      "type": "code",
      "context": "(first k+1 entries, last n-k-1 are zero) for k in range(1, n):",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 122,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3854",
      "raw": "norm_factor = 1.0 / np.sqrt(float(k * (k + 1)))",
      "type": "code",
      "context": "for k in range(1, n): E = np.zeros((n, n), dtype=np.float64)",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 123,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3855",
      "raw": "E[k, k] = -k * norm_factor",
      "type": "code",
      "context": "for i in range(k): E[i, i] = norm_factor",
