    },
    {
      "id": "eq_3851",
      "raw": "dim_sym0 = n * (n + 1) // 2 - 1  # = 35 for n=8",
      "type": "code",
      "context": "basis: (35, n, n) array of orthonormal traceless symmetric matrices \"\"\"",
