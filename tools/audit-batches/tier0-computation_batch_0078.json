      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 214,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3865",
      "raw": "dim_sym0 = basis.shape[0]",
      "type": "code",
      "context": "Tr(E^I (Ric E^J + E^J Ric)) = Tr(E^I Ric E^J) + Tr(E^I E^J Ric) Let's compute both terms:",
      "session": "",
      "source_file": "tier0-computation\\l20_lichnerowicz.py",
      "line": 232,
      "existing_latex": "",
      "audit_status": "none",
