      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3863",
      "raw": "R_endo = 0.5 * (R_endo + R_endo.T)",
      "type": "code",
