      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_3870",
      "raw": "term2 = np.einsum('Iab,Jba->IJ', E_Ric, basis)",
      "type": "code",
      "context": "Note: Tr(A @ B) = sum_{a,b} A_{ab} B_{ba} = einsum('ab,ba->', A, B) term1 = np.einsum('Iab,Jba->IJ', basis, Ric_E)",
      "session": "",
