      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5941",
      "raw": "Any departure from d_s = 8 at tau > 0 is a definitive signature of broken homogeneity.",
      "type": "code",
      "context": "For a d-dimensional Riemannian manifold, Weyl's law gives d_s -> d as sigma -> 0. At tau=0 (homogeneous SU(3)), d_s = 8 at ALL scales (high degeneracies enforce this).",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 11,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5942",
      "raw": "Compute heat kernel trace K(sigma) = Sum_n mult_n * exp(-sigma * lambda_n^2).",
      "type": "code",
      "context": "def compute_heat_kernel(eigenvalues, multiplicities, sigma_values): \"\"\"",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 45,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5943",
      "raw": "lam2 = eigenvalues ** 2",
      "type": "code",
      "context": "\"\"\" lambda_n^2 for each eigenvalue",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 58,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5944",
      "raw": "K = np.zeros(len(sigma_values))",
      "type": "code",
      "context": "lam2 = eigenvalues ** 2",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 60,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5945",
      "raw": "K[i] = np.sum(multiplicities * np.exp(-sigma * lam2))",
      "type": "code",
      "context": "for i, sigma in enumerate(sigma_values): exp(-sigma * lambda_n^2) with multiplicities",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 63,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5946",
      "raw": "Extract spectral dimension d_s = -2 * d(log K) / d(log sigma).",
      "type": "code",
      "context": "def spectral_dimension(K, sigma_values): \"\"\"",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 70,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5947",
      "raw": "log_K = np.log(K)",
      "type": "code",
      "context": "sigma_mid: sigma values at interior points \"\"\"",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 82,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5948",
      "raw": "log_sigma = np.log(sigma_values)",
      "type": "code",
      "context": "\"\"\" log_K = np.log(K)",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 83,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_5949",
      "raw": "d_log_K = np.gradient(log_K, log_sigma)",
      "type": "code",
      "context": "Central differences for d(log K)/d(log sigma)",
      "session": "19a",
      "source_file": "tier0-computation\\s19a_spectral_dimension.py",
      "line": 86,
      "existing_latex": "",
      "audit_status": "none",
