    {
      "id": "eq_6795",
      "raw": "e(TM) = (1/(2pi)^n) * Pf(Omega)",
      "type": "comment",
      "context": "Wait: the factor. Let me be very precise. The Euler class in dim=2n is:",
      "session": "21c",
