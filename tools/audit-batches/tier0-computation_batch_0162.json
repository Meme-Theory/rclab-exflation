      "severity": ""
    },
    {
      "id": "eq_6799",
      "raw": "# Each Omega^{ab} = (1/2) R^{ab}_{cd} e^c ^ e^d, so:",
      "type": "comment",
      "context": "Explicitly: Pf(Omega) = (1/(2^n n!)) * eps_{a1...a_{2n}} * Omega^{a1 a2} ^ ... ^ Omega^{a_{2n-1} a_{2n}}",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug5.py",
