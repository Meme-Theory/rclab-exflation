      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6800",
      "raw": "= (1/2^n) * sum R^{a1a2}_{c1d1} ... R^{a_{2n-1}a_{2n}}_{c_nd_n} * e^{c1}^e^{d1}^...^e^{cn}^e^{dn}",
