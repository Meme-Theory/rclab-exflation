    },
    {
      "id": "eq_6797",
      "raw": "Pf(A) = (1/(2^n n!)) * eps_{i1...i_{2n}} * A^{i1 i2} * ... * A^{i_{2n-1} i_{2n}}",
      "type": "comment",
      "context": "Omega^a_b = (1/2) R^a_{bcd} e^c ^ e^d Pf(A) for a 2n x 2n antisymmetric matrix:",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug5.py",
      "line": 148,
      "existing_latex": "",
