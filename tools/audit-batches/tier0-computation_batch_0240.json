      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_9773",
      "raw": "= (1/4) * 16 * [(-d_{km}d_{ln} + d_{kn}d_{lm})",
      "type": "comment",
      "context": "+(- d_{ln}d_{km} + d_{lm}d_{kn})] (the d_{kl}d_{mn} terms all cancel in pairs)",
