      "raw": "= (1/4) * 16 * [(d_{kl}d_{mn} - d_{km}d_{ln} + d_{kn}d_{lm})",
      "type": "comment",
      "context": "= (1/4) tr(gamma^k gamma^l gamma^m gamma^n - gamma^k gamma^l gamma^n gamma^m - gamma^l gamma^k gamma^m gamma^n + gamma^l gamma^k gamma^n gamma^m)",
