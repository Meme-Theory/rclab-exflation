      "severity": ""
    },
    {
      "id": "eq_9771",
      "raw": "= (1/4) tr(gamma^k gamma^l gamma^m gamma^n - gamma^k gamma^l gamma^n gamma^m",
      "type": "comment",
      "context": "tr([gamma^k,gamma^l][gamma^m,gamma^n])/4",
