    },
    {
      "id": "eq_2688",
      "raw": "2. T * Xi = Xi * conj(T)       (J-compatibility)",
      "type": "comment",
      "context": "The J-compatible commutant consists of complex matrices T satisfying: 1. [T, rho(v)] = 0 for all v  (gauge commutant)",
