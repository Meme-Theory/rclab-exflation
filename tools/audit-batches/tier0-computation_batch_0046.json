      "raw": "C * rho_+ = rho_- * C  (C intertwines Psi_+ to Psi_-)",
      "type": "comment",
      "context": "A * rho_+ = rho_+ * A  (A commutes with Psi_+ gauge action) B * rho_- = rho_+ * B  (B intertwines Psi_- to Psi_+)",
      "session": "",
      "source_file": "tier0-computation\\debug_jcompat2.py",
