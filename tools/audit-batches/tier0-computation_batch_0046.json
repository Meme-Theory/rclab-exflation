    },
    {
      "id": "eq_2689",
      "raw": "# Condition 2 in block form (T = (A,B;C,D), Xi = (0,-G5;-G5,0)):",
      "type": "comment",
      "context": "1. [T, rho(v)] = 0 for all v  (gauge commutant) 2. T * Xi = Xi * conj(T)       (J-compatibility)",
      "session": "",
