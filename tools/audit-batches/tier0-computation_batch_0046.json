      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_2694",
      "raw": "B * rho_- = rho_+ * B  (B intertwines Psi_- to Psi_+)",
      "type": "comment",
      "context": "This means: A * rho_+ = rho_+ * A  (A commutes with Psi_+ gauge action)",
      "session": "",
      "source_file": "tier0-computation\\debug_jcompat2.py",
      "line": 105,
      "existing_latex": "",
