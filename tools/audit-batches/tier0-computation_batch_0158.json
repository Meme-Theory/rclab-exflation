    {
      "id": "eq_6642",
      "raw": "# chi = integral Pf(Omega/(2pi))",
      "type": "comment",
      "context": "For m=4 (8-manifold): Pf(Omega) = (1/384) epsilon_{a1...a8} Omega^{a1 a2} ^ Omega^{a3 a4} ^ Omega^{a5 a6} ^ Omega^{a7 a8}",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
