    },
    {
      "id": "eq_6641",
      "raw": "Pf(Omega) = (1/384) epsilon_{a1...a8} Omega^{a1 a2} ^ Omega^{a3 a4} ^ Omega^{a5 a6} ^ Omega^{a7 a8}",
      "type": "comment",
      "context": "For m=4 (8-manifold):",
