      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6643",
      "raw": "= integral (1/(2pi)^4) Pf(Omega)",
      "type": "comment",
      "context": "chi = integral Pf(Omega/(2pi))",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 221,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6644",
      "raw": "= (1/(2pi)^4) * (1/384) * epsilon_a * [Omega^4]_top",
      "type": "comment",
      "context": "chi = integral Pf(Omega/(2pi)) = integral (1/(2pi)^4) Pf(Omega)",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 222,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6645",
      "raw": "Omega^{ab} = R^{ab}_{cd} e^c ^ e^d / 2 (summing over ALL c,d with antisymmetry)",
      "type": "comment",
      "context": "Now [Omega^{a1a2} ^ ... ^ Omega^{a7a8}]_top for specific a-values:",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 225,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6646",
      "raw": "= sum_{c<d} R^{ab}_{cd} e^c ^ e^d",
      "type": "comment",
      "context": "Now [Omega^{a1a2} ^ ... ^ Omega^{a7a8}]_top for specific a-values: Omega^{ab} = R^{ab}_{cd} e^c ^ e^d / 2 (summing over ALL c,d with antisymmetry)",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 226,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6647",
      "raw": "= sum_{c_i < d_i} R^{a1a2}_{c1d1} ... R^{a7a8}_{c4d4} * e^{c1}^e^{d1}^...^e^{c4}^e^{d4}",
      "type": "comment",
      "context": "The wedge of 4 two-forms: Omega^{a1a2} ^ Omega^{a3a4} ^ Omega^{a5a6} ^ Omega^{a7a8}",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 230,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6648",
      "raw": "= sum_{c1<d1,...,c4<d4} R...R * epsilon(c1,d1,...,c4,d4) * vol_8",
      "type": "comment",
      "context": "Omega^{a1a2} ^ Omega^{a3a4} ^ Omega^{a5a6} ^ Omega^{a7a8} = sum_{c_i < d_i} R^{a1a2}_{c1d1} ... R^{a7a8}_{c4d4} * e^{c1}^e^{d1}^...^e^{c4}^e^{d4}",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 231,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6649",
      "raw": "where Q[k] = (q_{2k-1}, q_{2k}) with q_{2k-1} < q_{2k}.",
      "type": "comment",
      "context": "This equals: sum over pair-partitions Q of {0,...,7}: sgn(Q) * prod_k R^{a_{2k-1} a_{2k}}_{Q[k]}",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 236,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6650",
      "raw": "So: [Omega^{a1a2}^...^Omega^{a7a8}]_top = sum_{Q partitions} sgn(Q) * prod_k R^{a_{2k-1}a_{2k}}_{Q[k]}",
      "type": "comment",
      "context": "In the wedge product, we just concatenate: if all 8 indices are distinct, the result is epsilon(c1,d1,...,c4,d4) * vol_8.",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 244,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_6651",
      "raw": "= sum_{P partitions} sgn(P) * sum_{Q partitions} sgn(Q) * prod_k R^{P[k]}_{Q[k]}",
      "type": "comment",
      "context": "Then: epsilon_a * [Omega^4]_top",
      "session": "21c",
      "source_file": "tier0-computation\\s21c_gb_debug4.py",
      "line": 247,
      "existing_latex": "",
