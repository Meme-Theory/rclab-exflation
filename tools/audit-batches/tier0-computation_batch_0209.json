    },
    {
      "id": "eq_8588",
      "raw": "where G_tt = 5 (Baptista Paper 15, eq 3.79, sigma-model metric from KK",
      "type": "code",
      "context": "w(t) = p_tau / rho_tau",
      "session": "22d",
