      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_9751",
      "raw": "a_2 = (4pi)^{-4} tr(R/6 Id + E) Vol = (4pi)^{-4} * 16 * (R/6 + R/4) Vol",
      "type": "comment",
      "context": "Using Gilkey's formula for P = nabla*nabla + E with E = R/4 on spinors:",
      "session": "",
      "source_file": "tier0-computation\\sd20a_seeley_dewitt_gate.py",
      "line": 228,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
      "id": "eq_9752",
      "raw": "= (4pi)^{-4} * 16 * (5R/12) Vol",
      "type": "comment",
      "context": "Using Gilkey's formula for P = nabla*nabla + E with E = R/4 on spinors: a_2 = (4pi)^{-4} tr(R/6 Id + E) Vol = (4pi)^{-4} * 16 * (R/6 + R/4) Vol",
      "session": "",
      "source_file": "tier0-computation\\sd20a_seeley_dewitt_gate.py",
      "line": 229,
      "existing_latex": "",
      "audit_status": "none",
      "new_latex": "",
      "new_status": "",
      "error_note": "",
      "severity": ""
    },
    {
