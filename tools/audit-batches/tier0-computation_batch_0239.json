    },
    {
      "id": "eq_9750",
      "raw": "# Using Gilkey's formula for P = nabla*nabla + E with E = R/4 on spinors:",
      "type": "comment",
      "context": "The coefficients alpha, beta, gamma depend on the operator (scalar Laplacian, Dirac, etc.) but NOT on tau. For the Dirac operator D^2:",
      "session": "",
      "source_file": "tier0-computation\\sd20a_seeley_dewitt_gate.py",
      "line": 226,
      "existing_latex": "",
